# ══════════════════════════════════════════════════════════════
# TRADEX — Variables d'environnement
# Copie ce fichier en .env.local et remplis toutes les valeurs
# ══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── IA ────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Stripe ────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ── Resend (emails) ───────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Push Notifications (VAPID) ────────────────────────────────
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:contact@tradex.io

# ── Cron ──────────────────────────────────────────────────────
# Clé secrète pour sécuriser les routes cron (x-cron-secret header)
CRON_SECRET=change_me_in_production_use_random_32chars

# ── Capacitor (mobile) ────────────────────────────────────────
# Pas de variable ici — config dans capacitor.config.ts
